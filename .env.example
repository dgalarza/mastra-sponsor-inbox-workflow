# Optional model lane. If unset, the demo uses deterministic fallbacks so it can
# run during a recording without provider credentials.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
INBOX_CLASSIFIER_MODEL=gpt-4o-mini
SPONSOR_EXTRACTOR_MODEL=gpt-4o-mini

# Optional local OpenAI-compatible lanes. These default to the same local
# endpoints used by Emma v2: lianlidg/Ollama for the cheap classifier and
# gstudio/MLX for the stronger extraction/drafting lane.
LOCAL_CLASSIFIER_BASE_URL=http://lianlidg:11434/v1
LOCAL_CLASSIFIER_API_KEY=ollama
LOCAL_CLASSIFIER_MODEL=ministral-3:8b

LOCAL_EXTRACTOR_BASE_URL=http://gstudio:8081/v1
LOCAL_EXTRACTOR_API_KEY=mlx
LOCAL_EXTRACTOR_MODEL=mlx-community/Qwen3.6-35B-A3B-6bit

# Optional fallback used when a lane-specific base URL is not set.
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_API_KEY=

# Tavily powers sponsor-provided page extraction and external corroboration.
# If unset, the workflow records skipped evidence and the guardrail forces
# needs_review.
TAVILY_API_KEY=

# Mastra storage. LibSQL is used for app/workflow state; DuckDB is used for
# observability traces, logs, metrics, scores, and feedback.
DATABASE_URL=file:./mastra.db
OBSERVABILITY_DB_URL=mastra-observability.duckdb
